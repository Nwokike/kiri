{
  "name": "kiri",
  "version": "1.0.0",
  "description": "Kiri Labs — Software & AI, built lightweight and efficient",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./static/css/output.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./static/css/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  }
}