{
  "name": "kiri",
  "version": "1.0.0",
  "description": "Open-source research tools, developer utilities, and project showcases. Built for edge intelligence and low-resource environments.",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "npx @tailwindcss/cli -i ./static/css/global.css -o ./static/css/output.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./static/css/global.css -o ./static/css/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  }
}